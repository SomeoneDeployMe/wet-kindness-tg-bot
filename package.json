    "ts-node": "^10.9.2",
    "typescript": "^5.4.3"
  },
  "dependencies": {
    "@grammyjs/chat-members": "^1.1.0",
    "@supabase/supabase-js": "^2.49.4",
    "az": "^0.2.3",
    "dotenv": "^16.4.5",
    "grammy": "^1.21.2",
    "lowdb": "^7.0.1",
    "openai": "^4.97.0",
    "zod": "^3.24.4"
  }
