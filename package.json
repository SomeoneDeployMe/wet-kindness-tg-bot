{
  "name": "wet-kindness-tg-bot",
  "packageManager": "yarn@4.1.1",
  "scripts": {
    "start:dev": "nodemon --watch src --ext ts --exec ts-node src/bot.ts",
    "start:prod": "yarn run tsc && yarn run pm2 start --name wetkindnessbot dist/bot.js",
    "stop:prod": "yarn run pm2 stop wetkindnessbot"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "nodemon": "^3.1.0",
    "pm2": "^5.3.1",
    "prettier": "^3.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.3"
  },
  "dependencies": {
    "@gramio/format": "^0.9.0",
    "@grammyjs/chat-members": "^1.2.0",
    "@libsql/client": "^0.15.15",
    "@tavily/core": "^0.7.6",
    "az": "^0.2.3",
    "dotenv": "^16.4.5",
    "grammy": "^1.44.0",
    "lowdb": "^7.0.1",
    "marked": "^15.0.11",
    "openai": "^6.42.0",
    "zod": "^3.25.0"
  }
}
